MANAGEMENT_PUBLIC_URL=https://your-server:8081

# Optional: disable the browser management UI while keeping the API and agent WebSocket available.
# MANAGEMENT_UI_DISABLED=false

# Optional: include extra hostnames/IPs in the auto-generated management TLS cert.
# MANAGEMENT_TLS_EXTRA_HOSTS=proxy.example.com,192.0.2.10

# Optional: encrypt stored upstream/API credentials in SQLite.
# Generate with: p2pstream secrets generate-key
# SECRETS_ENCRYPTION_KEY=
# Prefer SECRETS_ENCRYPTION_KEY_FILE when your secret manager can mount the key as a file.
# SECRETS_ENCRYPTION_KEY_FILE=
# SECRETS_ENCRYPTION_KEY_ID=primary
# SECRETS_ENCRYPTION_PREVIOUS_KEYS=
# Existing plaintext deployments should start once with false, then switch to true.
# SECRETS_ENCRYPTION_REQUIRED=true

P2PSTREAM_HTTP_PORT=80
P2PSTREAM_HTTPS_PORT=443
P2PSTREAM_MANAGEMENT_PORT=8081
